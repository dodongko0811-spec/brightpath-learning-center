rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /contact_inquiries/{document} {
      allow create: if request.resource.data.keys().hasOnly([
        'name',
        'age',
        'email',
        'message',
        'recipient',
        'source',
        'submittedAt',
        'status'
      ])
      && request.resource.data.name is string
      && request.resource.data.age is string
      && request.resource.data.email is string
      && request.resource.data.message is string
      && request.resource.data.recipient is string
      && request.resource.data.source == 'brightpath-learning-center'
      && request.resource.data.submittedAt is string
      && request.resource.data.status == 'new';

      allow read, update, delete: if false;
    }

    match /site_events/{document} {
      allow create: if request.resource.data.keys().hasOnly([
        'name',
        'path',
        'label',
        'details',
        'source',
        'timestamp'
      ])
      && request.resource.data.name is string
      && request.resource.data.path is string
      && request.resource.data.label is string
      && request.resource.data.details is map
      && request.resource.data.source == 'BrightPath Learning Center'
      && request.resource.data.timestamp is string;

      allow read, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
